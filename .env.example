# ---------------------------------------------------------------------------
# Veloura environment configuration
# Copy this file to .env and fill in real values for local development.
# ---------------------------------------------------------------------------

# Database (Neon Postgres in production, local Docker Postgres in dev)
DATABASE_URL=postgresql+psycopg://veloura:veloura@localhost:5433/veloura?sslmode=disable

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Auth
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (comma separated list of allowed origins)
VELOURA_CORS_ALLOWED_ORIGINS=http://localhost:5173

LOG_LEVEL=INFO
ENVIRONMENT=development

# Frontend (Vite reads this at build time)
VITE_API_BASE_URL=http://localhost:8000/api
